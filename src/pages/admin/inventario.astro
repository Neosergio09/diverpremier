---
export const prerender = false;
import AdminLayout from "@layouts/AdminLayout.astro";
import { supabase } from "@lib/supabase";
import type { Database } from "../../types/database";

// 1. Traemos el catálogo completo
const { data: catalog, error } = await supabase
  .from("view_product_catalog")
  .select("*")
  .returns<Database["public"]["Views"]["view_product_catalog"]["Row"][]>();

// 2. Traemos las categorías para el mapeo
const { data: categories } = await supabase
  .from("categories")
  .select("id, name");

// 🧠 LÓGICA DE AGRUPAMIENTO
const groupedCatalog = catalog?.reduce((acc, item) => {
  const category = item.category_name || "Sin Categoría";
  if (!acc[category]) acc[category] = [];
  acc[category].push(item);
  return acc;
}, {} as Record<string, typeof catalog>);

const pageTitle = "Gestión de Inventario";
---

<AdminLayout title={`${pageTitle} - Diverpremier Admin`}>
  <div class="max-w-6xl mx-auto">
    <header
      class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12"
    >
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          <span
            class="text-xs font-bold text-teal-500/70 uppercase tracking-[0.2em]"
            >Recursos</span
          >
        </div>
        <h1 class="text-4xl font-black text-white tracking-tight">
          {pageTitle}
        </h1>
        <p class="text-neutral-500 mt-2 font-medium">
          Monitoreo segmentado por categorías de búnker.
        </p>
      </div>

      <div class="flex gap-4">
        <input type="file" id="csv-upload" accept=".csv" class="hidden" />
        <button id="btn-bulk-upload" class="btn-secondary">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mr-1"
            ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
            ></path><polyline points="17 8 12 3 7 8"></polyline><line
              x1="12"
              x2="12"
              y1="3"
              y2="15"></line>
          </svg>
          Carga Masiva (CSV)
        </button>
        <button class="btn-primary">Añadir Producto</button>
      </div>
    </header>

    <div class="space-y-16">
      {
        error && (
          <div class="p-8 rounded-3xl bg-red-500/10 border border-red-500/20 text-red-400 text-center">
            Error al conectar con el búnker.
          </div>
        )
      }

      {
        groupedCatalog &&
          Object.entries(groupedCatalog).map(([categoryName, products]) => (
            <section class="animate-in fade-in slide-in-from-bottom-4 duration-700">
              <div class="flex items-center gap-4 mb-6">
                <h2 class="text-xl font-bold text-white uppercase tracking-[0.15em]">
                  {categoryName}
                </h2>
                <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent" />
                <span class="px-3 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-mono text-neutral-500">
                  {products.length} ITEMS
                </span>
              </div>

              <div class="rounded-3xl bg-neutral-900/40 border border-white/5 p-2 backdrop-blur-md overflow-x-auto">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr>
                      <th class="table-head pl-6">Producto</th>
                      <th class="table-head">Precio</th>
                      <th class="table-head">Stock</th>
                      <th class="table-head">Estado</th>
                      <th class="table-head text-right pr-6">Acciones</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/5">
                    {products.map((item) => (
                      <tr class="group hover:bg-white/[0.02] transition-colors">
                        <td class="py-5 pl-6">
                          <div class="flex flex-col">
                            <span class="text-sm font-bold text-white group-hover:text-teal-400 transition-colors">
                              {item.product_name}
                            </span>
                            <span class="text-[9px] font-mono text-neutral-600 uppercase mt-0.5">
                              ID: {item.uuid.split("-")[0]}
                            </span>
                          </div>
                        </td>
                        <td class="py-5 text-sm font-medium text-neutral-300">
                          ${item.price.toLocaleString("es-CO")}
                        </td>
                        <td class="py-5 text-sm font-mono text-neutral-400">
                          {item.stock_quantity ?? 0}
                        </td>
                        <td class="py-5">
                          <span
                            class={`status-badge ${
                              item.stock_status === "IN STOCK"
                                ? "status-green"
                                : item.stock_status === "LOW STOCK"
                                ? "status-yellow"
                                : "status-red"
                            }`}
                          >
                            {item.stock_status}
                          </span>
                        </td>
                        <td class="py-5 pr-6 text-right">
                          <button class="action-btn">Editar</button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))
      }
    </div>
  </div>
</AdminLayout>

<script define:vars={{ categories }}>
  const fileInput = document.getElementById("csv-upload");
  const uploadBtn = document.getElementById("btn-bulk-upload");

  uploadBtn?.addEventListener("click", () => fileInput?.click());

  fileInput?.addEventListener("change", async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = async (event) => {
      const text = event.target.result;
      // 1. Manejo robusto de filas (limpia espacios en blanco al final)
      const rows = text.split(/\r?\n/).filter((line) => line.trim() !== "");

      // 2. Detectar separador (Coma o Punto y Coma)
      const separator = rows[0].includes(";") ? ";" : ",";
      const dataRows = rows.slice(1);

      const productsToInsert = dataRows
        .map((line) => {
          const row = line.split(separator);
          if (row.length < 5) return null;

          // Limpieza de datos por columna
          const csvCategory = row[0]?.trim() || "";
          const csvName = row[1]?.trim() || "";
          const csvPresentation = row[2]?.trim() || "";
          const csvPrice = row[3]?.trim() || "0";
          const csvStock = row[4]?.trim() || "0";

          // 3. Match de Categoría (Flexible: quita espacios y mayúsculas)
          const category = categories.find(
            (c) => c.name.trim().toLowerCase() === csvCategory.toLowerCase()
          );

          // 4. Limpieza de Precio (Quita $, puntos de miles y deja solo números)
          const cleanPrice =
            parseFloat(csvPrice.replace(/[^0-9,.]/g, "").replace(",", ".")) ||
            0;

          return {
            // Unimos Marca + Presentación para que el nombre sea útil en la DB
            name: `${csvName} ${csvPresentation}`.trim(),
            description: `Formato: ${csvPresentation}`,
            price: cleanPrice,
            stock_quantity: parseInt(csvStock.replace(/\D/g, "")) || 0,
            category_id: category ? category.id : null,
            is_active: true,
          };
        })
        .filter((p) => p !== null);

      if (productsToInsert.length > 0) {
        console.log("📤 Cargando al búnker:", productsToInsert);
        const response = await fetch("/api/bulk-products", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(productsToInsert),
        });

        if (response.ok) {
          window.location.reload();
        } else {
          alert("Error en el búnker de datos. Revisa la consola.");
        }
      }
    };
    reader.readAsText(file);
  });
</script>
