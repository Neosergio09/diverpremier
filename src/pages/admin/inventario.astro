---
import AdminLayout from "@layouts/AdminLayout.astro";
import { supabase } from "@lib/supabase";
import type { Database } from "../../types/database";

// Fetch full catalog from view
const { data: catalog, error } = await supabase
  .from('view_product_catalog')
  .select('*')
  .returns<Database['public']['Views']['view_product_catalog']['Row'][]>();

const pageTitle = "Gestión de Inventario";
---

<AdminLayout title={`${pageTitle} - Diverpremier Admin`}>
  <div class="max-w-6xl mx-auto">
    <header class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-teal-500"></span>
          <span class="text-xs font-bold text-teal-500/70 uppercase tracking-[0.2em]">Recursos</span>
        </div>
        <h1 class="text-4xl font-black text-white tracking-tight">{pageTitle}</h1>
        <p class="text-neutral-500 mt-2 font-medium">Monitoreo en tiempo real de productos, categorías y existencias.</p>
      </div>
      
      <button class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-2xl bg-teal-500 text-neutral-950 font-bold text-sm hover:bg-teal-400 hover:-translate-y-0.5 transition-all shadow-lg shadow-teal-500/20 active:scale-95">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Añadir Producto
      </button>
    </header>

    <div class="grid grid-cols-1 gap-8">
      <section class="rounded-3xl bg-neutral-900/40 border border-white/5 p-8 backdrop-blur-md">
        {error ? (
          <div class="py-20 text-center">
            <p class="text-red-400 font-bold">Error al conectar con el búnker de datos.</p>
          </div>
        ) : (
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="border-b border-white/5">
                  <th class="py-4 text-xs font-bold text-neutral-500 uppercase tracking-widest pb-6">Producto</th>
                  <th class="py-4 text-xs font-bold text-neutral-500 uppercase tracking-widest pb-6">Categoría</th>
                  <th class="py-4 text-xs font-bold text-neutral-500 uppercase tracking-widest pb-6">Precio</th>
                  <th class="py-4 text-xs font-bold text-neutral-500 uppercase tracking-widest pb-6">Estado Stock</th>
                  <th class="py-4 text-xs font-bold text-neutral-500 uppercase tracking-widest pb-6 text-right">Acciones</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                {catalog?.map(item => (
                  <tr class="group hover:bg-white/[0.02] transition-colors">
                    <td class="py-6">
                      <div class="flex flex-col">
                        <span class="text-sm font-bold text-white group-hover:text-teal-400 transition-colors">{item.product_name}</span>
                        <span class="text-[10px] font-mono text-neutral-600 mt-1 uppercase">UID: {item.uuid.split('-')[0]}</span>
                      </div>
                    </td>
                    <td class="py-6">
                       <span class="px-2 py-1 rounded-lg bg-white/5 border border-white/10 text-[10px] font-bold text-neutral-400 uppercase tracking-wider">
                         {item.category_name || 'Sin categoría'}
                       </span>
                    </td>
                    <td class="py-6">
                      <span class="text-sm font-bold text-white">${item.price.toFixed(2)}</span>
                    </td>
                    <td class="py-6">
                      <span class={`inline-flex items-center gap-2 px-2.5 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-widest border ${
                        item.stock_status === 'IN STOCK' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20' :
                        item.stock_status === 'LOW STOCK' ? 'bg-amber-500/10 text-amber-400 border-amber-500/20' :
                        'bg-red-500/10 text-red-500 border-red-500/20'
                      }`}>
                        <span class={`w-1.5 h-1.5 rounded-full ${
                          item.stock_status === 'IN STOCK' ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]' :
                          item.stock_status === 'LOW STOCK' ? 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.5)]' :
                          'bg-red-500'
                        }`}></span>
                        {item.stock_status}
                      </span>
                    </td>
                    <td class="py-6 text-right">
                      <div class="flex items-center justify-end gap-2">
                         <button title="Editar" class="p-2 rounded-xl bg-white/5 border border-white/10 text-neutral-400 hover:text-white transition-all">
                           <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                         </button>
                         <button title="Eliminar" class="p-2 rounded-xl bg-red-500/5 border border-red-500/10 text-red-400/70 hover:text-red-400 hover:bg-red-500/20 transition-all">
                           <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                         </button>
                      </div>
                    </td>
                  </tr>
                ))}
                {(!catalog || catalog.length === 0) && (
                  <tr>
                    <td colspan="5" class="py-20 text-center">
                       <div class="flex flex-col items-center gap-4">
                         <div class="w-12 h-12 rounded-2xl bg-white/5 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-neutral-600"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
                         </div>
                         <p class="text-neutral-500 font-medium">No se encontraron productos en el inventario.</p>
                       </div>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </div>
  </div>
</AdminLayout>
