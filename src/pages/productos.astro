---
import MainLayout from "../layouts/MainLayout.astro";
import { Image } from 'astro:assets';
import { supabase } from '../lib/supabase';
import { formatCOP } from '../lib/formatters';

interface Product {
  name: string;
  price: number | string;
  stock_quantity: number;
  category_id?: string;
}

interface Category {
  name: string;
  products: Product[];
}

let categories: Category[] = [];
let fetchError: string | null = null;

try {
  console.log('--- Fetching Categories and Products from Supabase ---');
  const { data, error } = await supabase
    .from('categories')
    .select('name, products(name, price, stock_quantity, category_id)')
    .order('name');

  if (error) {
    console.error('❌ Supabase Error:', error.message);
    throw error;
  }
  
  console.log(`✅ Fetched ${data?.length || 0} categories.`);
  if (data) {
    data.forEach(cat => {
      console.log(`- Category "${cat.name}": ${cat.products?.length || 0} products`);
    });
  }
  
  categories = data || [];
} catch (e: any) {
  fetchError = e.message || "Error al conectar con la base de datos";
}
---

<MainLayout title="Productos" containerClass="max-w-7xl" isProse={false}>
  <div class="space-y-16 pb-20">
    <header class="text-center space-y-6 pt-10">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neon-blue/10 border border-neon-blue/30 text-neon-blue text-[10px] font-black uppercase tracking-[0.3em] animate-pulse"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-neon-blue opacity-75"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-neon-blue"
          ></span>
        </span>
        Abierto 24/7 en Engativá
      </div>
      <h1
        class="text-4xl sm:text-6xl md:text-8xl font-black italic tracking-tighter uppercase leading-none text-white"
      >
        <span class="neon-glow-blue">Licores</span>
        <br />
        <span
          class="text-transparent bg-clip-text bg-gradient-to-r from-neon-pink to-neon-purple"
          >Premium</span
        >
      </h1>
      <p class="text-slate-300 text-lg md:text-xl max-w-xl mx-auto font-medium">
        Tus marcas favoritas con entrega en <span
          class="text-white border-b border-neon-blue/50">menos de 30 min</span
        >.
      </p>
    </header>

    {fetchError ? (
      <div class="p-8 text-center glass-neon rounded-2xl border border-red-500/30 text-red-400">
        <h2 class="text-2xl font-bold mb-2">Error de Conexión</h2>
        <p>{fetchError}</p>
      </div>
    ) : (
      <>
        <nav
          class="flex overflow-x-auto py-2 gap-3 sm:gap-4 no-scrollbar sticky top-20 md:top-24 z-30 bg-dark-bg/80 backdrop-blur-md -mx-6 px-6"
        >
          {categories.map((cat, index) => (
            <button
              class:list={[
                 "px-5 sm:px-8 py-3 min-h-[44px] min-w-[44px] rounded-2xl glass-neon border transition-all duration-300 font-bold uppercase text-xs tracking-widest whitespace-nowrap flex items-center justify-center",
                index === 0
                  ? "border-neon-blue text-neon-blue bg-neon-blue/10 shadow-[0_0_15px_rgba(0,209,255,0.2)]"
                  : "border-white/10 text-slate-400 hover:border-white/30 hover:text-white",
              ]}
            >
              {cat.name}
            </button>
          ))}
        </nav>

        <div class="space-y-20 pt-8">
          {categories.map((category) => (
            <section class="space-y-8 relative">
              <h2 class="sticky top-32 md:top-36 z-20 py-4 bg-dark-bg/90 backdrop-blur-md text-2xl sm:text-3xl lg:text-4xl font-black italic uppercase tracking-widest text-white border-b border-white/10">
                {category.name}
              </h2>

              {category.products && category.products.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-12">
                  {category.products.map((product, index) => {
                    const priceFormatted = formatCOP(product.price);

                    return (
                      <article class="group relative flex flex-col h-full animate-reveal" style={`animation-delay: ${(index + 1) * 0.1}s;`}>
                        <div class="absolute -inset-1 bg-gradient-to-r from-neon-blue to-neon-purple rounded-[2.5rem] blur opacity-0 group-hover:opacity-20 transition duration-500" />

                        <div class="relative flex flex-col h-full glass-neon rounded-[2rem] border border-white/5 overflow-hidden transition-transform duration-500 group-hover:-translate-y-2">
                          <div class="relative aspect-[4/5] overflow-hidden bg-[#0A0F1E]">
                            <Image width={800} height={800} loading="lazy"
                              src={'https://placehold.co/600x800/0A0F1E/white?text=Producto'}
                              alt={product.name}
                              class="w-full h-full object-contain p-8 transition-transform duration-700 group-hover:scale-110"
                            />
                            
                            <div class="absolute top-4 left-4">
                              <span class:list={[
                                "px-3 py-1 rounded-lg text-[9px] font-black uppercase tracking-tighter backdrop-blur-md border",
                                product.stock_quantity > 0 
                                  ? "bg-neon-blue/20 border-neon-blue/50 text-neon-blue" 
                                  : "bg-black/60 border-neon-pink/50 text-neon-pink"
                              ]}>
                                {product.stock_quantity > 0 ? `Stock: ${product.stock_quantity}` : "Agotado"}
                              </span>
                            </div>
                          </div>

                          <div class="p-6 flex flex-col flex-grow">
                            <div class="mb-4">
                              <p class="text-[10px] font-black uppercase tracking-[0.3em] text-neon-purple mb-1">
                                {category.name}
                              </p>
                              <h3 class="text-xl font-bold text-white group-hover:text-neon-blue transition-colors line-clamp-2 min-h-[3.5rem]">
                                {product.name}
                              </h3>
                            </div>

                            <div class="mt-auto pt-4 border-t border-white/5 flex items-center justify-between">
                              <div class="flex flex-col">
                                <span class="text-[10px] text-slate-300 uppercase font-bold">
                                  Precio
                                </span>
                                <span class="text-2xl font-black text-white tracking-tighter">
                                  {priceFormatted}
                                </span>
                              </div>

                              <button 
                                class="add-to-cart-btn flex items-center justify-center w-12 h-12 rounded-xl bg-neon-pink/10 border border-neon-pink/40 text-neon-pink hover:bg-neon-pink hover:text-white hover:shadow-[0_0_20px_rgba(255,0,229,0.6)] transition-all duration-300 active:scale-90 group/btn"
                                data-name={product.name}
                                data-price={priceFormatted}
                                data-image={'https://placehold.co/600x800/0A0F1E/white?text=Producto'}
                              >
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  width="20"
                                  height="20"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="2.5"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  class="group-hover/btn:scale-110 transition-transform"
                                >
                                  <path d="M5 12h14" />
                                  <path d="m12 5 7 7-7 7" />
                                </svg>
                              </button>
                            </div>
                          </div>
                        </div>
                      </article>
                    );
                  })}
                </div>
              ) : (
                <div class="p-8 text-center border-2 border-dashed border-white/10 rounded-2xl glass-neon">
                  <p class="text-slate-400 font-medium">No hay productos disponibles en esta categoría por el momento.</p>
                </div>
              )}
            </section>
          ))}
        </div>
      </>
    )}
  </div>
</MainLayout>

<script>
  import { addItem, isCartOpen } from "../store/cartStore";

  const buttons = document.querySelectorAll(".add-to-cart-btn") as NodeListOf<HTMLButtonElement>;

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const { name, price, image } = btn.dataset;
      if (name && price && image) {
        addItem({ name, price, image_url: image });
        isCartOpen.set(true);
      }
    });
  });
</script>
