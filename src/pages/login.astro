---
import MainLayout from "@layouts/MainLayout.astro";
import LiquidBackground from "@components/ui/LiquidBackground.astro";
---

<MainLayout title="Acceso al Búnker | Diverpremier">
  <link
    slot="head"
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap"
    rel="stylesheet"
  />

  <LiquidBackground />

  <div
    class="fixed inset-0 flex items-center justify-center md:justify-end md:pr-80 px-6 z-10 overflow-hidden"
  >
    <div
      class="hidden md:flex absolute left-10 lg:left-40 bottom-0 w-1/2 h-4/5 items-end justify-start pointer-events-none select-none"
    >
      <svg
        viewBox="0 0 500 500"
        class="w-full h-full drop-shadow-[0_20px_50px_rgba(0,0,0,0.3)] overflow-visible"
      >
        <g>
          <rect
            x="240"
            y="220"
            width="70"
            height="180"
            rx="12"
            fill="#11021b"
            stroke="#38BDF8"
            stroke-width="0.5"></rect>
          <g id="char-black" class="character-face" data-speed="0.08">
            <circle cx="265" cy="250" r="8" fill="white"></circle><circle
              cx="265"
              cy="250"
              r="4"
              fill="black"
              class="eye-pupil"></circle>
            <circle cx="285" cy="250" r="8" fill="white"></circle><circle
              cx="285"
              cy="250"
              r="4"
              fill="black"
              class="eye-pupil"></circle>
            <line
              x1="265"
              y1="285"
              x2="285"
              y2="285"
              stroke="white"
              stroke-width="1.5"
              stroke-linecap="round"></line>
          </g>
        </g>
        <g>
          <rect x="130" y="100" width="110" height="300" rx="20" fill="#D052FF"
          ></rect>
          <g id="char-purple" class="character-face" data-speed="0.12">
            <ellipse cx="165" cy="150" rx="12" ry="15" fill="white"
            ></ellipse><circle
              cx="165"
              cy="150"
              r="6"
              fill="black"
              class="eye-pupil"></circle>
            <ellipse cx="205" cy="150" rx="12" ry="15" fill="white"
            ></ellipse><circle
              cx="205"
              cy="150"
              r="6"
              fill="black"
              class="eye-pupil"></circle>
            <path
              d="M170,210 Q185,230 200,210"
              fill="none"
              stroke="black"
              stroke-width="3"
              stroke-linecap="round"></path>
          </g>
        </g>
        <g>
          <path
            d="M260,400 L260,320 C260,280 300,280 340,280 C380,280 380,320 380,400 Z"
            fill="#BEF264"></path>
          <g id="char-lime" class="character-face" data-speed="0.1">
            <circle cx="320" cy="315" r="10" fill="white"></circle><circle
              cx="320"
              cy="315"
              r="5"
              fill="black"
              class="eye-pupil"></circle>
            <circle cx="320" cy="345" r="4" fill="black"></circle>
          </g>
        </g>
        <g>
          <path d="M40,400 A100,100 0 0,1 240,400 Z" fill="#FB923C"></path>
          <g id="char-orange" class="character-face" data-speed="0.15">
            <circle cx="160" cy="330" r="7" fill="black" class="eye-pupil"
            ></circle><circle
              cx="190"
              cy="330"
              r="7"
              fill="black"
              class="eye-pupil"></circle>
            <path
              d="M165,360 Q175,370 185,360"
              fill="none"
              stroke="black"
              stroke-width="3"
              stroke-linecap="round"></path>
          </g>
        </g>
      </svg>
    </div>

    <div
      class="w-full max-w-md backdrop-blur-3xl bg-white/[0.03] ring-1 ring-white/20 border border-white/10 rounded-[3rem] p-12 shadow-2xl relative overflow-hidden group z-10"
    >
      <div
        class="absolute -top-32 -right-32 w-64 h-64 bg-neon-blue/15 blur-[100px] rounded-full group-hover:bg-neon-blue/25 transition-colors duration-1000"
      >
      </div>
      <div class="relative z-10 text-center">
        <h1
          class="text-5xl font-['Bebas_Neue'] text-white tracking-widest uppercase italic mb-12"
        >
          DIVERPREMIER <span class="text-neon-blue neon-glow-text">GO</span>
        </h1>
        <form class="space-y-8" onsubmit="return false;">
          <input
            type="email"
            id="email-field"
            placeholder="agente@diverpremier.go"
            class="input-bunker"
          />
          <input
            type="password"
            id="pass-field"
            placeholder="••••••••"
            class="input-bunker"
          />
          <button type="submit" class="btn-bunker">Entrar al Búnker</button>
        </form>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  const faces = document.querySelectorAll(".character-face");
  const pupils = document.querySelectorAll(".eye-pupil");
  const emailInput = document.getElementById("email-field");
  const passInput = document.getElementById("pass-field");

  let isAnimating = false;

  // 🕒 Manejo de Estados de Tiempo y Curva
  const setMode = (mode) => {
    const config =
      mode === "anim"
        ? "transform 1s cubic-bezier(0.4, 0, 0.2, 1)"
        : "transform 0.15s ease-out";
    faces.forEach((f) => ((f as any).style.transition = config));
    pupils.forEach((p) => ((p as any).style.transition = config));
  };

  // 🖱️ Mouse Seguimiento (Con límites naturales)
  window.addEventListener("mousemove", (e) => {
    if (isAnimating) return;
    const x = (e.clientX - window.innerWidth / 2) / (window.innerWidth / 2);
    const y = (e.clientY - window.innerHeight / 2) / (window.innerHeight / 2);

    faces.forEach((f) => {
      const s = parseFloat(f.getAttribute("data-speed") || "0.1");
      // Limitamos el movimiento del mouse para que no se "desarmen"
      const moveX = x * (s * 60);
      const moveY = y * (s * 40);
      (f as any).style.transform = `translate(${moveX}px, ${moveY}px)`;
    });
    pupils.forEach((p) => {
      (p as any).style.transform = `translate(${x * 5}px, ${y * 5}px)`;
    });
  });

  // 🕵️ Evento: Email (Chisme calibrado)
  emailInput?.addEventListener("focus", () => {
    if (isAnimating) return;
    isAnimating = true;
    setMode("anim");

    const c = {
      black: document.getElementById("char-black"),
      purple: document.getElementById("char-purple"),
      lime: document.getElementById("char-lime"),
      orange: document.getElementById("char-orange"),
    };

    // Mirada al naranja (Ajustada para que no se pierdan ojos)
    if (c.black) c.black.style.transform = "translate(-18px, 12px)";
    if (c.purple) c.purple.style.transform = "translate(10px, 20px)";
    if (c.lime) c.lime.style.transform = "translate(-25px, 8px)";
    if (c.orange) c.orange.style.transform = "translate(5px, -5px)";

    setTimeout(() => c.orange?.classList.add("nodding"), 1200);

    setTimeout(() => {
      c.orange?.classList.remove("nodding");
      // Mirada al formulario (Ajustada)
      faces.forEach(
        (f) => ((f as any).style.transform = `translate(30px, 5px) scaleX(1)`)
      );
    }, 2500);

    setTimeout(() => {
      isAnimating = false;
      setMode("mouse");
    }, 5000);
  });

  // 🔒 Evento: Password (Privacidad con Margen y Escala)
  passInput?.addEventListener("focus", () => {
    isAnimating = true;
    setMode("anim");
    faces.forEach((f) => {
      // Usamos -25px para mantener la cara dentro del cuerpo + scaleX para el efecto de giro
      (f as any).style.transform = "translate(-25px, -10px) scaleX(0.9)";
    });
    pupils.forEach((p) => {
      (p as any).style.transform = "translate(-6px, -2px)";
    });
  });

  passInput?.addEventListener("blur", () => {
    isAnimating = false;
    // Volvemos a escala normal
    faces.forEach((f) => ((f as any).style.transform = "scaleX(1)"));
    setMode("mouse");
  });
</script>

<style>
  @reference "@styles/global.css";

  .character-face,
  .eye-pupil {
    transition: transform 0.15s ease-out;
    transform-origin: center; /* Crucial para el efecto de escala */
  }

  @keyframes nod {
    0%,
    100% {
      transform: translate(5px, -5px);
    }
    50% {
      transform: translate(5px, 10px);
    }
  }
  .nodding {
    animation: nod 0.8s ease-in-out;
  }

  .neon-glow-text {
    text-shadow: 0 0 15px rgba(56, 189, 248, 0.5);
  }
  .input-bunker {
    @apply w-full bg-white/[0.02] border border-white/5 rounded-2xl px-6 py-5 text-sm text-white placeholder:text-neutral-700 focus:outline-none focus:border-neon-blue/40 focus:bg-white/[0.05] transition-all duration-300;
  }
  .btn-bunker {
    @apply w-full py-5 rounded-[2rem] bg-neon-blue/5 border border-neon-blue/20 text-2xl font-['Bebas_Neue'] text-neon-blue uppercase tracking-[0.2em] hover:bg-neon-blue hover:text-black hover:shadow-[0_0_50px_rgba(56,189,248,0.6)] transition-all duration-700 mt-6 outline-none;
  }
</style>
