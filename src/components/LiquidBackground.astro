        ---
        /* src/components/LiquidBackground.astro */
        ---

        <div id="liquid-wrap" class="fixed inset-0 overflow-hidden pointer-events-none" style="z-index: -1;">
        <canvas id="liquid-canvas" style="width: 100%; height: 100%; display: block;"></canvas>
        </div>

        <script>
        // Guard to prevent multiple animation loops (critical with Astro View Transitions)
        let animationId: number | null = null;
        let cleanupResize: (() => void) | null = null;

        function initLiquidBg() {
            console.log('🌊 LiquidBackground: Iniciando...');

            // Cancel any previous animation loop before starting a new one
            if (animationId !== null) {
            cancelAnimationFrame(animationId);
            animationId = null;
            }
            if (cleanupResize) {
            cleanupResize();
            cleanupResize = null;
            }

            const canvas = document.getElementById('liquid-canvas') as HTMLCanvasElement | null;
            if (!canvas) {
            console.warn('🌊 LiquidBackground: canvas no encontrado.');
            return;
            }

            const ctx = canvas.getContext('2d');
            if (!ctx) {
            console.warn('🌊 LiquidBackground: 2D context no disponible.');
            return;
            }

            // --- Colors: hardcoded HEX so we don't depend on CSS custom property resolution ---
            const NEON_BLUE   = '#38BDF8'; // --color-neon-blue
            const NEON_PURPLE = '#D052FF'; // --color-neon-purple
            const NEON_PINK   = '#F472B6'; // --color-neon-pink

            let width = 0;
            let height = 0;
            let offset = 0;
            let running = true;

            function resize() {
            // Set the canvas BITMAP dimensions (not just CSS size)
            width  = canvas.width  = window.innerWidth;
            height = canvas.height = window.innerHeight;
            console.log(`🌊 Canvas resize: ${width}×${height}`);
            }

            function drawWave(
            color: string,
            alpha: number,
            yBase: number,
            freqA: number,
            freqB: number,
            ampA: number,
            ampB: number,
            shift: number
            ) {
            ctx.beginPath();
            ctx.strokeStyle = color;
            ctx.globalAlpha = alpha;
            ctx.lineWidth   = 3;
            ctx.shadowBlur  = 30;
            ctx.shadowColor = color;

            for (let x = 0; x <= width; x += 4) {
                const y =
                Math.sin(x * freqA + shift)          * ampA +
                Math.sin(x * freqB + shift * 1.3)    * ampB +
                yBase;

                if (x === 0) ctx.moveTo(x, y);
                else         ctx.lineTo(x, y);
            }
            ctx.stroke();
            ctx.shadowBlur  = 0;
            ctx.globalAlpha = 1;
            }

            function draw() {
            if (!running) return;

            ctx.clearRect(0, 0, width, height);
            offset += 0.006;

            // Wave 1 — Neon Blue (dominant, near center-bottom)
            drawWave(NEON_BLUE,   0.55, height * 0.65, 0.0018, 0.005, 60, 20, offset);

            // Wave 2 — Purple (deeper, slower)
            drawWave(NEON_PURPLE, 0.40, height * 0.78, 0.0022, 0.004, 50, 25, offset * 0.75);

            // Wave 3 — Pink (subtle accent, near top)
            drawWave(NEON_PINK,   0.25, height * 0.35, 0.0015, 0.006, 40, 15, offset * 0.5 + 1.5);

            animationId = requestAnimationFrame(draw);
            }

            const onResize = () => resize();
            window.addEventListener('resize', onResize);
            cleanupResize = () => window.removeEventListener('resize', onResize);

            resize();
            draw();
        }

        // Astro View Transitions: fires on every page navigation
        document.addEventListener('astro:page-load', () => {
            initLiquidBg();
        });

        // Fallback for hard refresh or no View Transitions
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initLiquidBg);
        } else {
            initLiquidBg();
        }
        </script>

        <style>
        #liquid-canvas {
            /* Subtle blur for the 'Antigravity' glow diffusion effect.
            Previously 20px — too high, was erasing thin strokes entirely. */
            filter: blur(6px);
        }
        </style>