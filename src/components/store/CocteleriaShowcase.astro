---
import { Image } from 'astro:assets';
/* src/components/CocktailFan.astro */

const cocktails = [
    {
        id: "spectral",
        name: "Ginebra Espectral",
        description:
            "Infusión molecular de botánicos premium con un destello de luz ultravioleta.",
        price: "$42.000",
        image: "https://upload.wikimedia.org/wikipedia/commons/3/3d/Tanqueray_bottle.JPG", // Usa tus fotos reales aquí
        ingredients: ["https://placehold.co/150x300/020c1b/38BDF8?text=Tanqueray", "https://placehold.co/150x300/020c1b/38BDF8?text=Tónica"],
        palette: { primary: "#38BDF8", bg: "#020c1b" }, // Azul Neón
    },
    {
        id: "nebula",
        name: "Nebulosa de Moras",
        description:
            "Mezcla mística de frutos rojos y vodka con textura etérea.",
        price: "$38.000",
        image: "https://upload.wikimedia.org/wikipedia/commons/b/b9/Grey_Goose_Bottle.jpg",
        ingredients: ["https://placehold.co/150x300/11021b/D052FF?text=Goose", "https://placehold.co/150x300/11021b/D052FF?text=Moras"],
        palette: { primary: "#D052FF", bg: "#11021b" }, // Púrpura Neón
    },
    {
        id: "amber",
        name: "Pulso de Ámbar",
        description:
            "Whisky añejado en roble quemado con una esfera de hielo tallada.",
        price: "$45.000",
        image: "https://upload.wikimedia.org/wikipedia/commons/2/21/Johnnie_Walker_Black_Label.jpg",
        ingredients: ["https://placehold.co/150x300/1b020c/F472B6?text=Etiqueta", "https://placehold.co/150x300/1b020c/F472B6?text=Naranja"],
        palette: { primary: "#F472B6", bg: "#1b020c" }, // Rosa/Naranja Neón
    },
];
---

<div
    id="fan-showcase"
    class="relative min-h-[800px] w-full flex flex-col items-center justify-start overflow-hidden transition-colors duration-1000 py-20"
>
    <div class="text-center z-20 mb-10">
        <h2
            class="text-6xl md:text-8xl font-black uppercase italic text-white tracking-tighter"
        >
            Mixología <span
                id="dynamic-title"
                class="text-neon-blue transition-colors duration-500"
                >Experimental</span
            >
        </h2>
    </div>

    <div
        class="relative w-full max-w-5xl h-[500px] flex justify-center items-end pb-20"
    >
        {
            cocktails.map((c, index) => (
                <div
                    class="cocktail-card absolute w-[280px] md:w-[320px] cursor-pointer origin-bottom transition-all duration-500"
                    data-index={index}
                    data-primary={c.palette.primary}
                    data-bg={c.palette.bg}
                >
                    <div class="glass-neon rounded-[3rem] p-8 border border-white/10 relative group overflow-visible">
                        <div class="ingredients-popout absolute -top-12 left-1/2 -translate-x-1/2 flex gap-2 opacity-0 transition-all duration-700 pointer-events-none">
                            {c.ingredients.map((img) => (
                                <Image width={150} height={300} loading="lazy"
                                    src={img}
                                    alt="Ingredient"
                                    class="w-12 h-20 object-contain drop-shadow-[0_0_10px_rgba(255,255,255,0.5)]"
                                />
                            ))}
                        </div>

                        <Image width={800} height={800} loading="eager"
                            src={c.image}
                            alt={c.name}
                            class="w-full h-48 object-contain mb-6 drop-shadow-2xl active-image"
                        />

                        <div class="text-center space-y-2">
                            <span class="text-[10px] font-black uppercase tracking-[0.3em] text-white/40">
                                {c.price}
                            </span>
                            <h3 class="text-2xl font-black text-white italic uppercase leading-none">
                                {c.name}
                            </h3>
                            <p class="text-xs text-slate-400 line-clamp-2 mt-2 opacity-0 group-[.active]:opacity-100 transition-opacity">
                                {c.description}
                            </p>
                        </div>

                        <button class="mt-6 w-full py-4 bg-white/5 border border-white/10 rounded-2xl text-[10px] font-black uppercase tracking-widest text-white hover:bg-white hover:text-black transition-all opacity-0 group-[.active]:opacity-100">
                            Pedir Kit Completo
                        </button>
                    </div>
                </div>
            ))
        }
    </div>
</div>

<script>
    import { gsap } from "gsap";

    function initCocktailFan() {
        const cards = document.querySelectorAll(".cocktail-card");
        const container = document.getElementById("fan-showcase");
        const title = document.getElementById("dynamic-title");
        let activeIndex = 1; // Empezamos con el del medio

        function updateFan(newIndex: number) {
            activeIndex = newIndex;

            cards.forEach((card, i) => {
                const isSelected = i === activeIndex;
                const offset = i - activeIndex;
                const angle = offset * 15; // 15 grados de separación
                const x = offset * 220; // Separación horizontal
                const z = isSelected ? 50 : 0;
                const scale = isSelected ? 1.1 : 0.8;
                const opacity = isSelected ? 1 : 0.4;

                gsap.to(card, {
                    rotation: angle,
                    x: x,
                    z: z,
                    scale: scale,
                    opacity: opacity,
                    duration: 0.8,
                    ease: "power3.out",
                    overwrite: true,
                });

                if (isSelected) {
                    card.classList.add("active");
                    // Cambiar colores ambientales
                    const primary = card.getAttribute("data-primary");
                    const bg = card.getAttribute("data-bg");

                    if (container && bg) container.style.backgroundColor = bg;
                    if (title && primary) {
                        title.style.color = primary;
                        title.style.textShadow = `0 0 30px ${primary}66`;
                    }
                } else {
                    card.classList.remove("active");
                }
            });
        }

        cards.forEach((card, i) => {
            card.addEventListener("click", () => updateFan(i));
        });

        // Inicializar posición
        updateFan(activeIndex);
    }

    document.addEventListener("astro:page-load", initCocktailFan);
    if (document.readyState !== "loading") initCocktailFan();
</script>

<style>
    /* El truco del abanico: el punto de rotación está muy abajo */
    .cocktail-card {
        transform-origin: center 800px;
        perspective: 1000px;
    }

    .active .ingredients-popout {
        opacity: 1;
        transform: translate(-50%, -40px);
    }

    .glass-neon {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
    }
</style>
