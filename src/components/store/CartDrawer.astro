---
import { X, MessageCircle, ShoppingBasket } from "lucide-astro";
---

<!-- Overlay -->
<div
  id="cart-overlay"
  class="fixed inset-0 bg-[#050505]/80 backdrop-blur-sm z-[100] transition-all duration-500 opacity-0 pointer-events-none"
>
</div>

<!-- Drawer -->
<aside
  id="cart-drawer"
  class="fixed top-0 right-0 h-full w-full sm:w-[480px] bg-[#0A0F1E]/90 backdrop-blur-2xl z-[101] border-l border-white/5 translate-x-full transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1) flex flex-col shadow-[-20px_0_80px_rgba(0,0,0,0.8)]"
>
  <!-- Header -->
  <div class="p-8 border-b border-white/5 flex items-center justify-between bg-white/2">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-neon-blue/10 flex items-center justify-center border border-neon-blue/20">
        <ShoppingBasket class="text-neon-blue" size={20} />
      </div>
      <h2 class="text-2xl font-black italic uppercase tracking-tighter">
        Tu <span class="text-neon-blue neon-glow-blue">Pedido</span>
      </h2>
    </div>
    <button
      id="cart-close"
      class="p-3 rounded-xl bg-white/5 border border-white/10 text-white/40 hover:text-white hover:border-white/30 hover:bg-white/10 transition-all active:scale-90"
    >
      <X size={20} />
    </button>
  </div>

  <!-- Items -->
  <div id="cart-items" class="flex-grow overflow-y-auto p-8 space-y-6 no-scrollbar">
    <!-- Items go here -->
    <div id="cart-empty" class="h-full flex flex-col items-center justify-center text-center space-y-6 opacity-30">
        <div class="relative">
            <ShoppingBasket size={64} class="text-slate-400" />
            <div class="absolute inset-0 bg-neon-blue/20 blur-2xl rounded-full"></div>
        </div>
        <p class="text-[10px] font-black uppercase tracking-[0.4em] text-slate-300">El carrito está vacío</p>
    </div>
  </div>

  <!-- Footer -->
  <div class="p-8 border-t border-white/10 bg-[#0A0F1E] space-y-8">
    <div class="flex items-end justify-between">
      <div class="space-y-1">
        <span class="text-[10px] text-slate-400 font-black uppercase tracking-widest">Total Estimado</span>
        <div class="flex items-baseline gap-2">
            <span id="total-price" class="text-4xl font-black text-white italic tracking-tighter">$0</span>
            <span class="text-neon-pink text-xs font-black uppercase">COP</span>
        </div>
      </div>
      <button id="cart-clear" class="text-[9px] font-black uppercase tracking-widest text-slate-400 hover:text-neon-pink transition-colors mb-2">
        Vaciar Carrito
      </button>
    </div>

    <button
      id="whatsapp-btn"
      class="w-full relative group overflow-hidden bg-neon-pink text-white py-6 rounded-2xl font-black uppercase italic tracking-tighter text-xl transition-all hover:shadow-[0_0_40px_rgba(255,0,229,0.5)] active:scale-[0.98]"
    >
      <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
      <div class="flex items-center justify-center gap-3 relative z-10">
        <MessageCircle size={24} />
        <span>Confirmar en Engativá</span>
      </div>
    </button>
    
    <p class="text-[9px] text-center text-slate-400 uppercase tracking-widest font-bold">
      Entregas rápidas en <span class="text-white">Villas de Granada</span> y alrededores
    </p>
  </div>
</aside>

<script>
  import { cartItems, isCartOpen, removeItem, addItem, clearCart, cartTotal } from "../../store/cartStore";

  const drawer = document.getElementById("cart-drawer");
  const overlay = document.getElementById("cart-overlay");
  const closeBtn = document.getElementById("cart-close");
  const itemsContainer = document.getElementById("cart-items");
  const emptyState = document.getElementById("cart-empty");
  const totalEl = document.getElementById("total-price");
  const clearBtn = document.getElementById("cart-clear");
  const whatsappBtn = document.getElementById("whatsapp-btn");

  const formatPrice = (val: number) => new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(val);

  isCartOpen.subscribe(val => {
    if (val) {
      drawer?.classList.remove("translate-x-full");
      overlay?.classList.remove("opacity-0", "pointer-events-none");
    } else {
      drawer?.classList.add("translate-x-full");
      overlay?.classList.add("opacity-0", "pointer-events-none");
    }
  });

  closeBtn?.addEventListener("click", () => isCartOpen.set(false));
  overlay?.addEventListener("click", () => isCartOpen.set(false));
  clearBtn?.addEventListener("click", () => clearCart());

  cartItems.subscribe(items => {
    const entries = Object.values(items);
    if (!itemsContainer || !emptyState || !totalEl) return;

    if (entries.length === 0) {
      itemsContainer.innerHTML = '';
      itemsContainer.appendChild(emptyState);
      totalEl.textContent = "$0";
      return;
    }

    if (emptyState.parentNode === itemsContainer) itemsContainer.removeChild(emptyState);

    itemsContainer.innerHTML = entries.map(item => `
      <div class="flex gap-4 p-4 rounded-[2rem] glass-neon border border-white/5 animate-in fade-in slide-in-from-right-8 duration-500">
        <div class="w-24 h-28 rounded-2xl overflow-hidden bg-[#0A0F1E] border border-white/5 flex-shrink-0">
          <img src="${item.image}" alt="${item.name}" class="w-full h-full object-contain p-2">
        </div>
        <div class="flex flex-col justify-between py-1 flex-grow">
          <div>
            <h4 class="text-sm font-bold text-white leading-tight mb-1">${item.name}</h4>
            <p class="text-neon-pink font-black text-xs uppercase italic">${item.priceFormatted}</p>
          </div>
          
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4 bg-white/5 rounded-xl border border-white/5 px-3 py-1">
              <button class="cart-remove text-white/40 hover:text-white transition-colors" data-id="${item.id}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/></svg>
              </button>
              <span class="text-xs font-black text-white w-4 text-center">${item.quantity}</span>
              <button class="cart-add text-white/40 hover:text-white transition-colors" data-id="${item.id}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    `).join('');

    document.querySelectorAll('.cart-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        if (id) removeItem(id);
      });
    });

    document.querySelectorAll('.cart-add').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLElement).dataset.id;
        if (id && items[id]) {
            const it = items[id];
            addItem({ name: it.name, price: it.priceFormatted, image_url: it.image });
        }
      });
    });
  });

  cartTotal.subscribe(total => {
    if (totalEl) totalEl.textContent = formatPrice(total);
  });

  whatsappBtn?.addEventListener("click", () => {
    const items = Object.values(cartItems.get());
    if (items.length === 0) return;

    let message = "🍾 *NUEVO PEDIDO - LICORERA ENGATIVÁ*\n\n";
    items.forEach(item => {
      message += `• ${item.quantity}x ${item.name} ($${item.price.toLocaleString()})\n`;
    });
    message += `\n💰 *Total:* ${formatPrice(cartTotal.get())}\n`;
    message += `📍 *Dirección:* [Ingresa tu dirección aquí]\n`;
    message += `🏘️ *Barrio:* [Villas de Granada / Garcés Navas / etc]\n\n`;
    message += `_Enviado desde el catálogo digital Diverpremier._`;

    window.open(`https://wa.me/573000000000?text=${encodeURIComponent(message)}`, '_blank');
  });
</script>

<style>
  @reference "@styles/global.css";

  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .neon-glow-blue {
    text-shadow: 0 0 15px rgba(0, 209, 255, 0.4);
  }

  #cart-drawer {
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
