---
// src/components/ui/Footer.astro
---

<footer class="relative w-full min-h-[25vh] md:min-h-[30vh] bg-[#020617] overflow-hidden mt-24">
    
    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center pt-10">
        <div class="relative w-full flex items-center justify-center">
            <span id="phrase-1" class="absolute text-[10px] md:text-xs font-black uppercase tracking-[0.5em] italic text-neutral-600/80">
                DiverpremierGo
            </span>
            <span id="phrase-2" class="absolute text-[10px] md:text-xs font-black uppercase tracking-[0.4em] italic text-neutral-600/80">
                una experiencia diseñada por otterock
            </span>
        </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full z-20 pointer-events-none wave-container flex flex-col justify-end h-full">
        <svg class="absolute bottom-[-10%] left-0 w-[200%] h-auto animate-wave-delayed opacity-30 fill-cyan-900" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
            <path d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>

        <svg class="absolute bottom-[-5%] left-0 w-[200%] h-auto animate-wave opacity-50 fill-[#0ea5e9]/20 filter drop-shadow-[0_-10px_15px_rgba(14,165,233,0.3)]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 320">
            <path d="M0,96L48,112C96,128,192,160,288,160C384,160,480,128,576,122.7C672,117,768,139,864,165.3C960,192,1056,224,1152,213.3C1248,203,1344,149,1392,122.7L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
        </svg>
    </div>

    <div class="absolute left-0 top-0 h-full w-1/3 z-30 bg-gradient-to-r from-[#020617] to-transparent pointer-events-none"></div>
    <div class="absolute right-0 top-0 h-full w-1/3 z-30 bg-gradient-to-l from-[#020617] to-transparent pointer-events-none"></div>
</footer>

<style>
    @keyframes wave-heartbeat {
        0% { transform: translateY(60%) translateX(0); }
        50% { transform: translateY(5%) translateX(-10%); }
        100% { transform: translateY(60%) translateX(0); }
    }

    .animate-wave {
        animation: wave-heartbeat 10s ease-in-out infinite;
    }

    .animate-wave-delayed {
        animation: wave-heartbeat 10s ease-in-out infinite -5s;
    }

    @keyframes text-cycle-1 {
        0%, 45% { opacity: 1; transform: scale(1); }
        50%, 95% { opacity: 0; transform: scale(0.95); }
        100% { opacity: 1; transform: scale(1); }
    }

    @keyframes text-cycle-2 {
        0%, 45% { opacity: 0; transform: scale(0.95); }
        50%, 95% { opacity: 1; transform: scale(1); }
        100% { opacity: 0; transform: scale(0.95); }
    }

    #phrase-1 {
        animation: text-cycle-1 10s infinite ease-in-out;
    }

    #phrase-2 {
        animation: text-cycle-2 10s infinite ease-in-out;
    }
</style>