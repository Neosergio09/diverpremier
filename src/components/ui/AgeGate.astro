---
// AgeGate.astro - Búnker Nightclub Entrance
---

<div id="age-gate" class="fixed inset-0 z-[200] bg-black flex flex-col items-center justify-center overflow-hidden transition-opacity duration-1000">
  
  <!-- Left Door -->
  <div id="left-door" class="absolute top-0 left-0 w-1/2 h-full bg-neutral-950 border-r border-teal-500/20 shadow-[5px_0_30px_rgba(20,184,166,0.1)] z-0 origin-left"></div>
  
  <!-- Right Door -->
  <div id="right-door" class="absolute top-0 right-0 w-1/2 h-full bg-neutral-950 border-l border-teal-500/20 shadow-[-5px_0_30px_rgba(20,184,166,0.1)] z-0 origin-right"></div>

  <!-- Central Glassmorphism Panel -->
  <div id="age-gate-panel" class="glass-neon p-10 rounded-[2.5rem] border-white/5 relative z-10 text-center max-w-md mx-4 shadow-[0_20px_50px_rgba(0,0,0,0.8)] backdrop-blur-3xl bg-[#020617]/80">
    <div class="mb-6 flex justify-center">
      <div class="w-16 h-16 rounded-2xl bg-teal-500/10 flex items-center justify-center border border-teal-500/30 shadow-[0_0_20px_rgba(20,184,166,0.3)]">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-400 drop-shadow-[0_0_8px_rgba(45,212,191,0.8)]"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"></path><path d="m9 12 2 2 4-4"></path></svg>
      </div>
    </div>
    
    <h2 class="text-3xl font-black text-white tracking-tight uppercase italic mb-3 drop-shadow-[0_0_15px_rgba(255,255,255,0.2)]">
      ¿Control de Acceso?
    </h2>
    
    <p class="text-neutral-400 mb-10 text-sm font-medium leading-relaxed">
      Confirma que eres mayor de edad (+18) para ingresar al búnker de Diverpremier.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
      <button id="btn-age-yes" class="btn-primary py-3 px-8 text-sm w-full sm:w-auto animate-pulse shadow-[0_0_30px_rgba(20,184,166,0.3)] hover:shadow-[0_0_50px_rgba(20,184,166,0.6)]">
        SÍ, Soy Mayor (+18)
      </button>
      <button id="btn-age-no" class="btn-secondary py-3 px-8 text-sm w-full sm:w-auto">
        NO, Soy Menor
      </button>
    </div>
  </div>
</div>

<script is:inline>
  // Evitar Flash del Age Gate ejecutando la comprobación sincronamente antes del pintado del DOM
  if (typeof localStorage !== 'undefined' && localStorage.getItem('ageVerified') === 'true') {
    const gate = document.getElementById('age-gate');
    if (gate) gate.style.display = 'none';
  }

  document.addEventListener('astro:page-load', () => {
    const ageGate = document.getElementById('age-gate');
    if (!ageGate || ageGate.style.display === 'none') return;

    // Double check on page load for SPA navigations
    if (localStorage.getItem('ageVerified') === 'true') {
      ageGate.style.display = 'none';
      return;
    }

    const btnYes = document.getElementById('btn-age-yes');
    const btnNo = document.getElementById('btn-age-no');
    const panel = document.getElementById('age-gate-panel');
    const leftDoor = document.getElementById('left-door');
    const rightDoor = document.getElementById('right-door');

    btnNo?.addEventListener('click', () => {
      window.location.href = 'https://www.google.com';
    });

    btnYes?.addEventListener('click', () => {
      localStorage.setItem('ageVerified', 'true');

      // Animación del panel central
      panel?.classList.add('animate-out', 'fade-out', 'zoom-out-95', 'duration-500');
      
      // Animación de las puertas (Nightclub Effect)
      leftDoor?.classList.add('animate-out', 'slide-out-to-left', 'duration-1000', 'delay-300');
      rightDoor?.classList.add('animate-out', 'slide-out-to-right', 'duration-1000', 'delay-300');

      // Remover del DOM para que no bloquee clicks
      setTimeout(() => {
        ageGate.classList.add('pointer-events-none', 'opacity-0');
        setTimeout(() => {
            ageGate.style.display = 'none';
        }, 1000); // Darle tiempo al opacity transition
      }, 1300);
    });
  });
</script>
