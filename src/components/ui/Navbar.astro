---
import { MessageSquare, MapPin, FlaskConical } from "lucide-astro";

const navItems = [
  { name: "Inicio", url: "/" },
  { name: "Productos", url: "/productos" },
  { name: "Mapa", url: "/mapa" },
  { name: "Coctelería", url: "/cocteleria" },
];

const pathname = Astro.url.pathname;
const currentPath = pathname.endsWith("/") ? pathname : `${pathname}/`;
---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 z-[90] w-full max-w-7xl px-4">
  <div
    class="glass-neon border-neon-purple/30 rounded-3xl px-8 py-5 flex items-center justify-between relative overflow-hidden bg-[#020617]/60 backdrop-blur-xl"
  >
    <div class="flex items-center gap-2 relative z-10">
      <div class="p-1.5 bg-neon-blue/10 rounded-lg animate-pulse shadow-[0_0_15px_var(--color-neon-blue)]">
          <FlaskConical size={18} class="text-neon-blue" />
      </div>
      <span class="text-xl font-black italic tracking-tighter text-white uppercase">
        DIVERPREMIER <span class="text-neon-blue neon-glow-blue">GO</span>
      </span>
    </div>

    <ul class="hidden lg:flex items-center gap-10 relative z-10">
      {
        navItems.map((item) => {
          const isActive = currentPath === (item.url.endsWith("/") ? item.url : `${item.url}/`);
          return (
            <li class="relative py-2 group">
              <a
                href={item.url}
                class:list={[
                  "text-[11px] font-black uppercase tracking-[0.2em] transition-all duration-300",
                  isActive
                    ? "text-neon-blue"
                    : "text-slate-400 hover:text-neon-blue neon-glow-blue",
                ]}
              >
                {item.name}
              </a>

              {isActive && (
                <div
                  transition:name="navbar-active-line"
                  class="absolute -bottom-1 left-0 w-full h-[3px] rounded-full overflow-visible"
                >
                  <div class="w-full h-full bg-gradient-to-r from-transparent via-neon-blue to-white shadow-[0_0_15px_var(--color-neon-blue)]" />
                  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-1.5 h-1.5 bg-white rounded-full shadow-[0_0_15px_#fff]" />
                </div>
              )}
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-4 relative z-10">
      <div class="hidden md:flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/5 text-[10px] font-bold text-slate-300">
        <MapPin size={12} class="text-neon-purple" />
        Álamos, Bogotá
      </div>

      <button
        class="px-6 py-3 rounded-2xl bg-neon-blue/10 border border-neon-blue/30 text-[10px] font-black text-neon-blue hover:bg-neon-blue hover:text-dark-bg transition-all duration-500 uppercase tracking-[0.2em]"
      >
        WhatsApp
      </button>
    </div>

    <div class="absolute -left-10 -top-10 w-32 h-32 bg-neon-purple/10 blur-3xl rounded-full"></div>
  </div>
</nav>

<style is:global>
  @reference "@styles/global.css";

  ::view-transition-group(navbar-active-line) {
    animation-timing-function: cubic-bezier(0.68, -0.6, 0.32, 1.6);
    animation-duration: 0.5s;
  }

  .neon-glow-blue {
    text-shadow: 0 0 10px var(--color-neon-blue);
  }
</style>

<script>
  // Se eliminó la lógica del carrito para optimizar el rendimiento del lado del cliente.
</script>