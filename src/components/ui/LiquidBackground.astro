---
/* src/components/LiquidBackground.astro */
---

<div
    id="liquid-wrap"
    class="fixed inset-0 overflow-hidden pointer-events-none bg-[#020617] hidden md:block"
    style="z-index: 0;"
    transition:persist
>
    <canvas
        id="liquid-canvas"
        style="width: 100%; height: 100%; display: block;"></canvas>
</div>

<script>
    class LiquidEngine {
        private static instance: LiquidEngine | null = null;
        private canvas: HTMLCanvasElement;
        private ctx: CanvasRenderingContext2D;
        private animationId: number | null = null;
        private width: number = 0;
        private height: number = 0;
        private dpr: number = 1;
        private offset: number = 0;
        private ripples: any[] = [];
        private mouse = { x: -1000, y: -1000, active: false };
        private initialized: boolean = false;
        private isMobile: boolean = false;

        private readonly COLORS = [
            { h: 199, s: 89, l: 48, alpha: 0.6 }, // Neon Blue
            { h: 282, s: 100, l: 66, alpha: 0.4 }, // Purple Neon
            { h: 330, s: 98, l: 65, alpha: 0.3 }, // Pink Neon
        ];

        constructor(canvas: HTMLCanvasElement) {
            this.canvas = canvas;
            this.ctx = canvas.getContext("2d", { alpha: true })!;
            this.init();
        }

        public static getInstance(canvas: HTMLCanvasElement): LiquidEngine {
            if (!LiquidEngine.instance) {
                LiquidEngine.instance = new LiquidEngine(canvas);
            } else if (LiquidEngine.instance.canvas !== canvas) {
                LiquidEngine.instance.cleanup();
                LiquidEngine.instance = new LiquidEngine(canvas);
            }
            return LiquidEngine.instance;
        }

        private init() {
            if (this.initialized) return;
            
            this.resize();
            // Early return if mobile, engine won't run at all
            if (this.isMobile) return;

            this.addEventListeners();
            this.start();
            this.initialized = true;
        }

        private addEventListeners() {
            window.addEventListener("resize", this.handleResize);
            window.addEventListener("pointermove", this.handlePointerMove);
            document.addEventListener("astro:before-preparation", this.handleCleanup);
        }

        private handleCleanup = () => {
            this.cleanup();
        };

        private handleResize = () => {
            this.resize();
        };

        private resize() {
            this.width = window.innerWidth;
            this.height = window.innerHeight;
            this.dpr = window.devicePixelRatio || 1;
            this.isMobile = this.width < 768;

            // If we resized into mobile, stop everything
            if (this.isMobile) {
                this.stop();
                return;
            } else if (this.initialized && !this.animationId) {
                // If weresized out of mobile, restart if was initialized
                this.addEventListeners();
                this.start();
            }

            this.canvas.width = this.width * this.dpr;
            this.canvas.height = this.height * this.dpr;
            this.ctx.scale(this.dpr, this.dpr);
        }

        private handlePointerMove = (e: PointerEvent) => {
            this.updateInteraction(e.clientX, e.clientY);
        };

        private updateInteraction(x: number, y: number) {
            this.mouse.x = x;
            this.mouse.y = y;
            this.mouse.active = true;

            const maxRipples = this.isMobile ? 12 : 20;
            const threshold = this.isMobile ? 0.90 : 0.85;

            if (Math.random() > threshold && this.ripples.length < maxRipples) {
                const color = this.COLORS[Math.floor(Math.random() * this.COLORS.length)];
                this.ripples.push({
                    x: this.mouse.x,
                    y: this.mouse.y,
                    r: 5,
                    alpha: 0.8,
                    color: `hsla(${color.h}, ${color.s}%, ${color.l}%,`,
                });
            }
        }

        private drawWave(
            color: any,
            yBase: number,
            freqA: number,
            freqB: number,
            ampA: number,
            ampB: number,
            shift: number
        ) {
            const { ctx, width } = this;
            ctx.beginPath();
            ctx.strokeStyle = `hsla(${color.h}, ${color.s}%, ${color.l}%, ${color.alpha})`;
            ctx.lineWidth = 4;
            ctx.lineCap = "round";

            // Performance Tuning: Balance entre fluidez y CPU
            const step = this.isMobile ? 18 : 8;

            for (let x = 0; x <= width + step; x += step) {
                const dx = x - this.mouse.x;
                const dy = yBase - this.mouse.y;
                const dist = Math.sqrt(dx * dx + dy * dy);
                const mouseInertia = dist < 250 ? (1 - dist / 250) * 50 : 0;

                const y =
                    Math.sin(x * freqA + shift) * (ampA + mouseInertia) +
                    Math.sin(x * freqB + shift * 1.3) * ampB +
                    yBase;

                if (x === 0) ctx.moveTo(x, y);
                else ctx.lineTo(x, y);
            }
            ctx.stroke();
        }

        private updateRipples() {
            const { ctx } = this;
            for (let i = this.ripples.length - 1; i >= 0; i--) {
                const r = this.ripples[i];
                r.r += 2.5;
                r.alpha -= 0.01;

                if (r.alpha <= 0) {
                    this.ripples.splice(i, 1);
                    continue;
                }

                ctx.beginPath();
                ctx.arc(r.x, r.y, r.r, 0, Math.PI * 2);
                ctx.strokeStyle = `${r.color}${r.alpha})`;
                ctx.lineWidth = 2;
                ctx.stroke();
            }
        }

        private draw = () => {
            const { ctx, width, height } = this;
            ctx.fillStyle = "rgba(2, 6, 23, 0.2)";
            ctx.fillRect(0, 0, width, height);

            this.offset += 0.007;
            this.updateRipples();

            this.drawWave(this.COLORS[0], height * 0.65, 0.002, 0.005, 50, 20, this.offset);
            this.drawWave(this.COLORS[1], height * 0.75, 0.0025, 0.004, 40, 25, this.offset * 0.8);
            this.drawWave(this.COLORS[2], height * 0.35, 0.0015, 0.006, 30, 15, this.offset * 0.5 + 2);

            this.animationId = requestAnimationFrame(this.draw);
        };

        public start() {
            if (!this.animationId) this.draw();
        }

        public stop() {
            if (this.animationId) {
                cancelAnimationFrame(this.animationId);
                this.animationId = null;
            }
        }

        public cleanup() {
            this.stop();
            window.removeEventListener("resize", this.handleResize);
            window.removeEventListener("pointermove", this.handlePointerMove);
            document.removeEventListener("astro:before-preparation", this.handleCleanup);
            this.initialized = false;
        }
    }


    function init() {
        const canvas = document.getElementById("liquid-canvas") as HTMLCanvasElement;
        if (canvas) LiquidEngine.getInstance(canvas);
    }

    document.addEventListener("astro:page-load", init);
    if (document.readyState !== "loading") init();
</script>

<style>
    #liquid-canvas {
        /* REDUCIDO: De 40px a 12px para que las ondas se vean nítidas pero etéreas */
        filter: blur(12px);
        mix-blend-mode: screen;
    }
</style>
