---
import CheckoutForm from "../checkout/CheckoutForm.astro";
import { ShoppingCart } from "lucide-astro";
---
<div id="cart-drawer-overlay" class="fixed inset-0 z-[400] bg-black/80 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-500"></div>

<aside id="cart-drawer-wrapper" class="fixed top-0 right-0 w-full md:w-[480px] h-[100dvh] z-[410] translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.87,0,0.13,1)]">
  <div class="glass-neon h-full bg-[#020617]/95 border-l border-white/5 shadow-[-30px_0_60px_rgba(0,0,0,0.9)] flex flex-col pt-safe">
    
    <!-- Drawer Header -->
    <header class="p-6 md:p-8 border-b border-white/5 flex justify-between items-center bg-black/40 backdrop-blur-3xl shrink-0 z-20">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-neon-blue/10 flex items-center justify-center border border-neon-blue/30 shadow-[0_0_20px_rgba(56,189,248,0.2)]">
          <ShoppingCart class="text-neon-blue w-6 h-6" />
        </div>
        <div>
          <h2 class="text-white font-black text-xl uppercase tracking-tighter italic">Búnker Cart</h2>
          <span id="cart-count-badge" class="text-neon-blue text-[10px] font-mono font-bold uppercase tracking-widest">0 Items Registrados</span>
        </div>
      </div>
      <button id="cart-drawer-close" class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 text-slate-400 hover:text-white transition-all hover:rotate-90">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </header>

    <!-- Drawer Scrollable Content -->
    <div class="flex-1 overflow-y-auto no-scrollbar p-6 md:p-8 space-y-6 relative bg-gradient-to-b from-transparent to-[#020617]/50">
      
      <!-- Empty State -->
      <div id="empty-cart-msg" class="absolute inset-0 flex flex-col items-center justify-center text-center opacity-0 pointer-events-none transition-opacity duration-300">
        <div class="w-20 h-20 rounded-[2rem] bg-white/5 flex items-center justify-center mb-6 text-slate-600 border border-white/5 shadow-inner">
          <ShoppingCart class="w-10 h-10" />
        </div>
        <h3 class="text-white font-black text-lg uppercase tracking-wide mb-2">Cargamento Vacío</h3>
        <p class="text-slate-500 font-medium text-sm max-w-[200px]">No hay productos registrados en tu contenedor actual.</p>
      </div>

      <!-- Items List -->
      <div id="cart-items-container" class="space-y-4"></div>

      <!-- Checkout Module -->
      <div id="checkout-section-wrapper" class="hidden pt-8 border-t border-white/5 mt-8 animate-in fade-in duration-500">
        <CheckoutForm />
      </div>
    </div>

    <!-- Drawer Footer / Proceed Action -->
    <footer id="cart-footer" class="p-6 md:p-8 border-t border-white/5 bg-black/60 backdrop-blur-3xl shrink-0 z-20">
      <div class="flex justify-between items-end mb-4">
        <div class="flex flex-col">
          <span class="text-[9px] font-black text-neon-purple uppercase tracking-[0.3em] mb-1">Total Bunker Value</span>
          <span id="cart-total-value" class="text-3xl font-black text-white tracking-tighter">$0</span>
        </div>
        <button id="btn-show-checkout" class="px-8 py-4 rounded-2xl bg-white/10 border border-white/10 text-white text-[10px] font-black uppercase tracking-[0.2em] hover:bg-white/20 hover:scale-105 transition-all flex items-center gap-2 shadow-lg">
          Proceder 
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-neon-purple"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
    </footer>
  </div>
</aside>

<script>
  import { isCartOpen, cartItems, cartTotal, removeItem } from "../../store/cartStore";
  import { formatCOP } from "../../lib/formatters";

  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById("cart-drawer-overlay");
    const wrapper = document.getElementById("cart-drawer-wrapper");
    const closeBtn = document.getElementById("cart-drawer-close");
    const container = document.getElementById("cart-items-container");
    const emptyMsg = document.getElementById("empty-cart-msg");
    const totalEl = document.getElementById("cart-total-value");
    const countEl = document.getElementById("cart-count-badge");
    const btnShowCheckout = document.getElementById("btn-show-checkout");
    const checkoutWrapper = document.getElementById("checkout-section-wrapper");
    const footer = document.getElementById("cart-footer");

    // Toggle Visibility Logic
    isCartOpen.subscribe(open => {
      if (open) {
        overlay?.classList.remove("opacity-0", "pointer-events-none");
        wrapper?.classList.remove("translate-x-full");
      } else {
        overlay?.classList.add("opacity-0", "pointer-events-none");
        wrapper?.classList.add("translate-x-full");
        // Reset checkout view for next open
        setTimeout(() => {
          btnShowCheckout?.classList.remove("hidden");
          checkoutWrapper?.classList.add("hidden");
          const formEl = document.getElementById("checkout-form");
          formEl?.classList.add("hidden");
          formEl?.classList.remove("flex");
        }, 500);
      }
    });

    const closeDrawers = () => isCartOpen.set(false);
    overlay?.addEventListener("click", closeDrawers);
    closeBtn?.addEventListener("click", closeDrawers);

    // List Rendering
    cartItems.subscribe(items => {
      const itemsList = Object.values(items);
      
      if (countEl) countEl.innerText = `${itemsList.reduce((acc, i) => acc + i.quantity, 0)} Items Registrados`;
      
      if (itemsList.length === 0) {
        if (emptyMsg) emptyMsg.classList.remove("opacity-0", "pointer-events-none");
        if (container) container.innerHTML = '';
        if (footer) footer.style.display = 'none';
        btnShowCheckout?.classList.remove("hidden");
        checkoutWrapper?.classList.add("hidden");
      } else {
        if (emptyMsg) emptyMsg.classList.add("opacity-0", "pointer-events-none");
        if (footer) footer.style.display = 'block';

        if (container) {
          container.innerHTML = itemsList.map(item => `
            <div class="flex items-center gap-5 p-4 rounded-[2rem] bg-white/[0.03] border border-white/5 relative group hover:bg-white/[0.05] transition-colors">
              <div class="w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-[#0A0F1E] flex-shrink-0 border border-white/10 flex items-center justify-center p-2 shadow-inner">
                <img src="${item.image}" alt="${item.name}" class="w-full h-full object-contain mix-blend-screen" />
              </div>
              <div class="flex-1 min-w-0 pr-4">
                <h4 class="text-white font-bold text-sm truncate uppercase tracking-wider mb-1">${item.name}</h4>
                <div class="flex items-center justify-between mt-2">
                  <span class="text-teal-400 font-black text-sm tracking-wide bg-teal-400/10 px-2 py-0.5 rounded-md border border-teal-400/20">${formatCOP(item.price * item.quantity)}</span>
                  <div class="flex items-center justify-center w-8 h-8 bg-black/50 border border-white/10 rounded-xl relative overflow-hidden">
                    <span class="text-slate-500 font-black text-[9px] absolute top-0.5 left-1 uppercase tracking-tighter">QT</span>
                    <span class="text-white text-xs font-black absolute bottom-1 right-1.5">${item.quantity}</span>
                  </div>
                </div>
              </div>
              <button class="remove-btn absolute -top-2 -right-2 w-8 h-8 rounded-full bg-[#FF0066]/90 text-white opacity-0 group-hover:opacity-100 flex items-center justify-center transition-all duration-300 shadow-[0_0_15px_rgba(255,0,102,0.6)] hover:scale-110 hover:bg-[#FF0066]" data-id="${item.id}">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
          `).join('');

          // Bind Actions
          document.querySelectorAll(".remove-btn").forEach(btn => {
            btn.addEventListener("click", (e) => {
              const id = (e.currentTarget as HTMLButtonElement).getAttribute("data-id");
              if (id) removeItem(id);
            });
          });
        }
      }
    });

    // Total logic
    cartTotal.subscribe(val => {
      if (totalEl) totalEl.innerText = formatCOP(val);
    });

    // Proceed Reveal
    btnShowCheckout?.addEventListener("click", () => {
      btnShowCheckout.classList.add("hidden");
      checkoutWrapper?.classList.remove("hidden");
      const formEl = document.getElementById("checkout-form");
      formEl?.classList.remove("hidden");
      formEl?.classList.add("flex");
      
      setTimeout(() => {
        const drawerContent = document.querySelector("#cart-drawer-wrapper .overflow-y-auto");
        if (drawerContent) {
           drawerContent.scrollTo({ top: drawerContent.scrollHeight, behavior: 'smooth' });
        }
      }, 100);
    });
  });
</script>
