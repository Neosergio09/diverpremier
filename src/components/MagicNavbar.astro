---
import { Home, Package, Map, History, MessageSquare } from "lucide-astro";

const pathname = Astro.url.pathname;

// 1. Los 5 pilares de Diverpremier
const navItems = [
    { href: "/productos", icon: Package, label: "Tienda" },
    { href: "/mapa", icon: Map, label: "Mapa" },
    { href: "/", icon: Home, label: "Inicio" }, // CENTRO
    { href: "/pedidos", icon: History, label: "Pedidos" },
    { href: "/soporte", icon: MessageSquare, label: "Chat" },
];

// 2. Lógica para calcular dónde debe estar la burbuja
const activeIndex = navItems.findIndex((item) => {
    const p = pathname.replace(/\/$/, "") || "/";
    const h = item.href.replace(/\/$/, "") || "/";
    return p === h || (h !== "/" && p.startsWith(h));
});

const currentIndex = activeIndex === -1 ? 2 : activeIndex;
---

<div
    class="fixed bottom-0 left-0 w-full flex justify-center z-[100] md:hidden pb-8 px-4 pointer-events-none"
>
    <nav
        class="navigation pointer-events-auto relative w-full max-w-[360px] h-[70px] bg-[#020617]/90 backdrop-blur-xl rounded-2xl flex justify-center items-center px-2 shadow-2xl border border-white/10"
    >
        <div
            class="relative w-[300px]"
            style={`--active-index: ${currentIndex};`}
        >
            <div
                class="indicator absolute -top-[55%] left-0 w-[60px] h-[60px] bg-neon-blue rounded-full border-[6px] border-[#020617] transition-transform duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] shadow-[0_0_20px_rgba(56,189,248,0.5)]"
            >
                <div
                    class="absolute top-[50%] -left-[22px] w-[20px] h-[20px] bg-transparent rounded-tr-[20px] shadow-[2px_-10px_0_0_#020617]"
                >
                </div>
                <div
                    class="absolute top-[50%] -right-[22px] w-[20px] h-[20px] bg-transparent rounded-tl-[20px] shadow-[-2px_-10px_0_0_#020617]"
                >
                </div>
            </div>

            <ul
                class="flex relative w-full justify-between items-center h-full list-none p-0 m-0"
            >
                {
                    navItems.map((item, index) => (
                        <li
                            class={`relative w-[60px] h-[70px] z-10 flex-shrink-0 group ${
                                index === currentIndex ? "active" : ""
                            }`}
                        >
                            <a
                                href={item.href}
                                class="relative flex justify-center items-center flex-col w-full h-full"
                            >
                                <span class="icon relative block text-white/40 transition-all duration-500 h-[70px] flex items-center justify-center z-20 group-[.active]:-translate-y-9 group-[.active]:text-[#020617]">
                                    <item.icon size={24} strokeWidth={2.5} />
                                </span>
                                <span class="text absolute text-neon-blue font-black text-[9px] tracking-widest opacity-0 transition-all duration-500 translate-y-5 group-[.active]:opacity-100 group-[.active]:translate-y-5 uppercase">
                                    {item.label}
                                </span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </nav>
</div>

<style>
    .indicator {
        transform: translateX(calc(var(--active-index) * 60px));
    }
</style>
