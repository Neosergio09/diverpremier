---
import "@styles/global.css";
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
}

const { title = "Diverpremier Admin" } = Astro.props;
const adminName = "Sergio Bello";

const navItems = [
  { name: 'Dashboard', href: '/admin', icon: 'LayoutDashboard' },
  { name: 'Inventario', href: '/admin/inventario', icon: 'Package' },
  { name: 'Pedidos', href: '/admin/pedidos', icon: 'ShoppingCart' },
  { name: 'Analíticas', href: '/admin/analiticas', icon: 'BarChart3' },
];
---

<!DOCTYPE html>
<html lang="es" class="bg-neutral-950 text-neutral-200">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="font-['Inter',sans-serif] selection:bg-teal-500/30 overflow-hidden">
    <div class="flex h-screen w-full bg-neutral-950 overflow-hidden relative">
      <!-- Mobile Sidebar Overlay -->
      <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 lg:hidden opacity-0 pointer-events-none transition-opacity duration-300"></div>

      <!-- Sidebar -->
      <aside id="admin-sidebar" class="w-64 border-r border-white/5 bg-neutral-900/40 backdrop-blur-xl flex flex-col z-50 fixed inset-y-0 left-0 -translate-x-full lg:translate-x-0 lg:static transition-transform duration-300 ease-in-out">
        <div class="p-6 border-b border-white/5 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-teal-500 to-emerald-500 flex items-center justify-center shadow-lg shadow-teal-500/20">
            <span class="font-black text-neutral-950 text-xs">DP</span>
          </div>
          <span class="font-bold text-white tracking-tight">Diverpremier <span class="text-teal-500">Go</span></span>
        </div>

        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          {navItems.map((item) => (
            <a 
              href={item.href}
              class="flex items-center gap-3 px-4 py-3 rounded-xl text-neutral-400 hover:text-white hover:bg-white/5 transition-all duration-300 group"
            >
              <div class="w-5 h-5 opacity-70 group-hover:opacity-100 group-hover:text-teal-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  {item.name === 'Dashboard' && <><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></>}
                  {item.name === 'Inventario' && <><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></>}
                  {item.name === 'Pedidos' && <><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/></>}
                  {item.name === 'Analíticas' && <><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></>}
                </svg>
              </div>
              <span class="text-sm font-medium">{item.name}</span>
            </a>
          ))}
        </nav>

        <div class="p-4 border-t border-white/5">
          <div class="p-4 rounded-2xl bg-gradient-to-br from-teal-500/10 to-emerald-500/10 border border-teal-500/20">
            <p class="text-[10px] font-bold text-teal-500 uppercase tracking-widest mb-1">Status Sistema</p>
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
              <span class="text-[11px] font-medium text-neutral-300">Conectado al Búnker</span>
            </div>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 flex flex-col h-screen overflow-hidden">
        <!-- Topbar -->
        <header class="h-16 border-b border-white/5 bg-neutral-900/20 backdrop-blur-md flex items-center justify-between px-6 md:px-8 z-20">
          <div class="flex items-center gap-4">
             <!-- Hamburger Menu Button -->
             <button id="sidebar-toggle" class="lg:hidden p-2 rounded-xl bg-white/5 hover:bg-white/10 text-neutral-400 transition-all active:scale-95">
               <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
             </button>

             <div class="h-8 w-[1px] bg-white/10 hidden md:block"></div>
             <p class="text-sm text-neutral-400 hidden lg:block">Panel de Control Operativo</p>
          </div>
          
          <div class="flex items-center gap-6">
            <button class="relative w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 hover:border-white/20 text-neutral-400 hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
              <span class="absolute top-2 right-2 w-2 h-2 rounded-full bg-teal-500 border-2 border-neutral-900"></span>
            </button>
            
            <div class="flex items-center gap-3 pl-4 md:pl-6 border-l border-white/10">
              <div class="text-right flex flex-col hidden sm:flex">
                <span class="text-sm font-bold text-white leading-none">{adminName}</span>
                <span class="text-[10px] font-medium text-teal-500 uppercase tracking-wider">Administrador</span>
              </div>
              <div class="w-9 h-9 rounded-xl bg-neutral-800 border border-white/10 flex items-center justify-center overflow-hidden">
                <span class="text-xs font-bold text-neutral-300">SB</span>
              </div>
              <button title="Cerrar Sesión" class="p-2 text-neutral-500 hover:text-red-400 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              </button>
            </div>
          </div>
        </header>

        <!-- Content Area -->
        <div class="flex-1 overflow-y-auto overflow-x-hidden p-4 md:p-8">
          <slot />
        </div>
      </main>
    </div>

    <!-- Background Accents -->
    <div class="fixed inset-0 pointer-events-none -z-10 bg-neutral-950 overflow-hidden">
      <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-teal-500/10 blur-[120px] rounded-full"></div>
      <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] bg-emerald-500/10 blur-[120px] rounded-full"></div>
    </div>

    <script is:inline>
      const toggleBtn = document.getElementById("sidebar-toggle");
      const sidebar = document.getElementById("admin-sidebar");
      const overlay = document.getElementById("sidebar-overlay");

      function toggleSidebar() {
        sidebar.classList.toggle("-translate-x-full");
        overlay.classList.toggle("opacity-0");
        overlay.classList.toggle("pointer-events-none");
      }

      toggleBtn?.addEventListener("click", toggleSidebar);
      overlay?.addEventListener("click", toggleSidebar);
    </script>
	</body>
</html>
