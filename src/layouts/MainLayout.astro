---
import "@styles/global.css";
import { ClientRouter } from "astro:transitions";
import Navbar from "@components/ui/Navbar.astro";
import LiquidBackground from "@components/ui/LiquidBackground.astro";
import MagicNavbar from "@components/ui/MagicNavbar.astro"; // 👈 Importamos la pieza clave
import AgeGate from "@components/ui/AgeGate.astro";
import CartDrawer from "@components/cart/CartDrawer.astro";
import Footer from "@components/ui/Footer.astro";

interface Props {
    title: string;
    description?: string;
    containerClass?: string;
    isProse?: boolean;
}

const {
    title,
    description = "Diverpremier Go - Central de Inteligencia y Logística de Licores en Álamos, Bogotá.",
    containerClass = "",
    isProse = false,
} = Astro.props;

// Lógica para determinar el ancho del contenedor
const widthClass = containerClass
    ? containerClass
    : isProse
    ? "max-w-3xl"
    : "max-w-7xl";
---

<!DOCTYPE html>
<html lang="es" class="bg-dark-bg transition-colors duration-500">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />

        <title>{title} | Diverpremier Go</title>
        <meta name="description" content={description} />

        <ClientRouter />
        <slot name="head" />

        <!-- Theme Initialization Script -->
        <script is:inline>
            (function() {
                try {
                    const savedTheme = localStorage.getItem('theme');
                    const isSystemLight = window.matchMedia('(prefers-color-scheme: light)').matches;
                    if (savedTheme === 'light' || (!savedTheme && isSystemLight)) {
                        document.documentElement.classList.add('light');
                    }
                } catch (e) {}
            })();
        </script>
    </head>
    <body
        class="selection:bg-neon-pink selection:text-white antialiased text-body-color min-h-screen bg-transparent overflow-x-hidden relative transition-colors duration-500"
    >
        <LiquidBackground />

        <AgeGate />

        <CartDrawer />

        <Navbar />

        <main
            class:list={[
                "mx-auto pt-32 pb-48 px-6 relative z-10", // Aumentamos pb-32 a pb-48 para que la MagicNavbar no tape el contenido
                widthClass,
                { "prose prose-invert lg:prose-xl prose-neon": isProse },
            ]}
        >
            <slot />
        </main>

        <MagicNavbar />

        <Footer />

        <style is:global>
            @reference "@styles/global.css";

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
            }

            /* 🖋️ Refinamiento de la Letra Capital */
            .prose p:first-of-type::first-letter {
                @apply float-left text-7xl font-black mr-4 mt-2 text-neon-blue leading-[0.7];
                text-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
            }

            /* Estilos de Tipografía para modo oscuro */
            .prose-neon {
                --tw-prose-body: theme("colors.slate.300");
                --tw-prose-headings: theme("colors.white");
                --tw-prose-links: var(--color-neon-blue);
                --tw-prose-bold: theme("colors.white");
            }

        </style>
    </body>
</html>
