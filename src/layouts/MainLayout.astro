---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/Navbar.astro";
import LiquidBackground from "../components/LiquidBackground.astro";

interface Props {
    title: string;
    description?: string;
    containerClass?: string;
    isProse?: boolean;
}

const {
    title,
    description = "Diverpremier Go - Central de Inteligencia y Logística de Licores en Álamos, Bogotá.",
    // Si es Prose (texto), usamos un ancho de lectura. Si no, usamos el ancho de Dashboard.
    containerClass = "", 
    isProse = false,
} = Astro.props;

// Lógica para determinar el ancho del contenedor
const widthClass = containerClass ? containerClass : (isProse ? "max-w-3xl" : "max-w-7xl");
---

<!DOCTYPE html>
<html lang="es" class="bg-[#020617]">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{title} | Diverpremier Go</title>
        <meta name="description" content={description} />
        
        <ClientRouter />
    </head>
    <body class="selection:bg-neon-pink selection:text-white antialiased text-slate-300 min-h-screen bg-transparent overflow-x-hidden">
        
        <LiquidBackground />

        <Navbar />

        <main
            class:list={[
                "mx-auto pt-32 pb-20 px-6 relative z-10",
                widthClass,
                { "prose prose-invert lg:prose-xl prose-neon": isProse },
            ]}
        >
            <slot />
        </main>

        <style is:global>
            @reference "../styles/global.css";

            html {
                scroll-behavior: smooth;
            }

            body {
                margin: 0;
                /* Un toque de viñeta para dar profundidad al fondo neón */
                background-image: radial-gradient(
                    circle at 50% 50%,
                    transparent 0%,
                    rgba(2, 6, 23, 0.4) 100%
                );
            }

            /* 🖋️ Refinamiento de la Letra Capital */
            .prose p:first-of-type::first-letter {
                @apply float-left text-7xl font-black mr-4 mt-2 text-neon-blue leading-[0.7];
                text-shadow: 0 0 20px rgba(56, 189, 248, 0.4);
            }

            /* Estilos de Tipografía para modo oscuro */
            .prose-neon {
                --tw-prose-body: theme('colors.slate.300');
                --tw-prose-headings: theme('colors.white');
                --tw-prose-links: var(--color-neon-blue);
                --tw-prose-bold: theme('colors.white');
            }

            /* Utilidad para esconder scrollbars sin perder la función */
            .no-scrollbar::-webkit-scrollbar {
                display: none;
            }
            .no-scrollbar {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }
        </style>
    </body>
</html>